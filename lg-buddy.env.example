# lg-buddy configuration — installed to /etc/lg-buddy/lg-buddy.env
# (Ansible renders this from host_vars; this file documents the knobs.)

TV_IP=192.168.1.100
TV_MAC=AA:BB:CC:DD:EE:FF
TV_INPUT=HDMI_2

# WebOS pairing token DB. Put it on a partition that survives an OS-drive
# wipe so the TV never re-prompts for pairing after a reinstall.
PAIRING_DB=/mnt/nvme1/lg-buddy/pairing.db

# bscpylgtv CLI inside the venv the installer creates.
BSCPYLGTV=/opt/lg-buddy/venv/bin/bscpylgtvcommand

# Cold-start tuning (optional).
WOL_COUNT=3
INPUT_RETRIES=3
